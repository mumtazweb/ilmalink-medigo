# Azure Translator config
TRANSLATION_PROVIDER=azure
AZURE_TRANSLATOR_KEY=your_azure_translator_key
AZURE_TRANSLATOR_REGION=centralindia
# Optional; defaults to https://api.cognitive.microsofttranslator.com when unset
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# Existing Hostinger MySQL database used by Prisma
DATABASE_URL=mysql://database_user:database_password@database_host:3306/database_name

# Education Portal signed session security (generate a random 32+ character value)
PORTAL_SESSION_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_SITE_HOST=www.ilmalink.com
# Optional persistent private directory for student document uploads
PORTAL_DOCUMENT_UPLOAD_DIR=/absolute/path/to/private/portal-documents
# Optional first-time staff bootstrap used by scripts/grant-portal-access.mjs
PORTAL_BOOTSTRAP_EMAIL=existing_blog_admin_email
PORTAL_BOOTSTRAP_ROLE=super_admin

# Hostinger SMTP (Resend remains a supported fallback when RESEND_API_KEY exists)
SMTP_HOST=your_hostinger_smtp_host
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=middya@ilmalink.com
SMTP_PASS=your_email_password_or_app_password
MAIL_FROM="ILMALINK MEDIGO <middya@ilmalink.com>"
LEAD_ALERT_TO=injamulhoquemiddya@gmail.com

# Student OTP policy
OTP_LENGTH=4
OTP_EXPIRY_MINUTES=5
OTP_RESEND_SECONDS=45
OTP_MAX_ATTEMPTS=3

# Student SMS OTP provider: msg91, fast2sms, or custom
SMS_PROVIDER=msg91
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=your_sender_id
SMS_TEMPLATE_ID=your_dlt_template_id
# Required only when SMS_PROVIDER=custom
SMS_API_URL=https://your-sms-provider.example/send
# One-time owner bootstrap (never commit the real password)
OWNER_ADMIN_EMAIL=injamulhoquemiddya@gmail.com
OWNER_ADMIN_NAME=ILMALINK Owner Admin
OWNER_ADMIN_PASSWORD=
